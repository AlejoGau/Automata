# Server Config
PORT=3001

# Supabase Credentials
# Note: Use service role key to allow the backend to bypass RLS policies for webhooks
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Evolution API
EVOLUTION_API_URL=https://your-evolution-api-url.com
EVOLUTION_API_KEY=your-evolution-api-token
EVOLUTION_INSTANCE_NAME=Automata
EVOLUTION_WEBHOOK_SECRET=your-webhook-secret-token

# URL pública de ESTE backend (la que Evolution usará para mandar webhooks).
# La usa "npm run webhook:setup". Ej: https://crm-backend.tudominio.com
PUBLIC_BACKEND_URL=https://your-public-backend-url.com
