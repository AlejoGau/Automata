# Server Config
PORT=3001

# Supabase Credentials
# Note: Use service role key to allow the backend to bypass RLS policies for webhooks
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Proveedor de WhatsApp activo: "evolution" (default) o "cloud" (Meta Cloud API)
WHATSAPP_PROVIDER=evolution


# Evolution API
EVOLUTION_API_URL=https://your-evolution-api-url.com
EVOLUTION_API_KEY=your-evolution-api-token
EVOLUTION_INSTANCE_NAME=Automata
EVOLUTION_WEBHOOK_SECRET=your-webhook-secret-token

# WhatsApp Cloud API (Meta) — se usa cuando WHATSAPP_PROVIDER=cloud
# El token temporal dura ~24h; luego crear uno permanente con un usuario del sistema.
META_ACCESS_TOKEN=your-temporary-or-permanent-access-token
META_PHONE_NUMBER_ID=1149528651583377
META_WABA_ID=2148334212376597
META_GRAPH_VERSION=v22.0
# Token que vos elegís para verificar el webhook GET (se usará en el Paso 2 - recepción)
META_VERIFY_TOKEN=un-string-secreto-que-vos-elijas
# App Secret de la App de Meta, para validar la firma X-Hub-Signature-256 (Paso 2)
META_APP_SECRET=your-meta-app-secret

# ─────────────────────────────────────────────────────────────
# MARKETING STUDIO — Agente de generación de videos
# ─────────────────────────────────────────────────────────────
# API de Claude (Anthropic): orquesta al agente director de video
CLAUDE_API_KEY=your-anthropic-api-key
# Bucket de Supabase Storage donde viven las skills (SKILL.md)
MARKETING_SKILLS_BUCKET=skills
# Fotos/videos de stock REALES y gratis (base visual del video)
PEXELS_API_KEY=your-pexels-api-key
# Voz (opcional): narración TTS. Dejar vacío para arrancar solo con subtítulos.
ELEVENLABS_API_KEY=
# Puente (opcional): carpeta del claude-code-video-toolkit. Si se define, el
# brief generado se copia a <toolkit>/briefs/ listo para /video.
MARKETING_TOOLKIT_DIR=

# URL pública de ESTE backend (la que Evolution usará para mandar webhooks).
# La usa "npm run webhook:setup". Ej: https://crm-backend.tudominio.com
PUBLIC_BACKEND_URL=https://your-public-backend-url.com
