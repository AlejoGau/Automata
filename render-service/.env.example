# Puerto del servicio de render
PORT=3002

# Secreto compartido: el backend de Automata manda este token en el header
# 'x-render-secret' para autorizar los pedidos de render. Poné un valor largo y random.
RENDER_SHARED_SECRET=

# ElevenLabs (voz). Sin esto, el video se renderiza SIN audio.
ELEVENLABS_API_KEY=
# Voz por defecto (es-AR). Cambiá por el voiceId que prefieras.
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Supabase (para subir el mp4 y devolver un link). Reutilizá las mismas del backend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Bucket donde se guardan los renders (crealo público o con signed URLs).
RENDER_BUCKET=renders

# Concurrencia de Remotion (frames en paralelo). En un server de 7.8GB, 2-3 es seguro.
REMOTION_CONCURRENCY=2
